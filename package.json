    "@tanstack/query-core": "^5.99.0",
    "@tanstack/query-db-collection": "^1.0.36",
    "@tanstack/react-db": "^0.1.83"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.7",
    "@types/node": "^25.0.3",
    "bumpp": "^10.3.2",
    "tsdown": "^0.18.1",
    "typescript": "^5.9.3",
    "ultracite": "7.3.2",
    "vitest": "^4.0.16",
    "zod": "^4.3.6"
  },
  "directories": {
    "test": "tests"
  },
  "repository": {
    "type": "git",
