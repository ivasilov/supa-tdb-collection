{
  "name": "supa-tdb-collection",
  "type": "module",
  "version": "0.0.1",
  "description": "A library for creating a Supabase collection.",
  "author": "Ivan Vasilov",
  "license": "MIT",
  "exports": {
    ".": "./dist/index.mjs",
    "./package.json": "./package.json"
  },
  "main": "./dist/index.mjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
